# Firestore persistence (client SDK only). Set to "true" to use Firestore instead of localStorage.
# Requires a Firebase project with a Firestore database.
NEXT_PUBLIC_USE_FIRESTORE=

# Firebase config — only required when NEXT_PUBLIC_USE_FIRESTORE=true.
# Firebase Console → Project settings → General → Your apps (Web SDK config).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Supabase (Google sign-in). Dashboard → API: project URL and anon (public) key.
# NEXT_SUPABASE_SERVICE_ROLE_KEY: same dashboard, "service_role" secret — used server-side to create the "audios" storage bucket if it is missing (no manual bucket setup).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_SUPABASE_SERVICE_ROLE_KEY=

# Audio library and AI chat: comma-separated Supabase user UUIDs with admin access (server / API routes).
NEXT_USER_ADMIN=
# Same UUIDs as above — needed in the browser for admin UI (e.g. "save to library" on a scene). Only NEXT_PUBLIC_* vars are available client-side.
NEXT_PUBLIC_USER_ADMIN=
# Anthropic API key for AI chat (server-only). Create a key: https://console.anthropic.com/
NEXT_ANTHROPIC_API_KEY=
# Optional: Claude model id (default: claude-opus-4-5).
# NEXT_ANTHROPIC_MODEL=claude-opus-4-5

# Pixabay Sounds API — primary source for high-quality audio. Keys: https://pixabay.com/api/docs/
NEXT_PIXABAY_API_KEY=
# Optional: base URL for sound search JSON (default https://pixabay.com/api/sounds/) if Pixabay changes the endpoint.
# NEXT_PIXABAY_SOUNDS_API_URL=

# Optional: Serper web search for AI chat (https://serper.dev).
# NEXT_SERPER_API_KEY=

# Support / donations: Pix via Mercado Pago (server); Stripe/GitHub links (public).
# Mercado Pago: Production or Test access token (Dashboard → Your integration → Credentials). Never expose as NEXT_PUBLIC_*.
MERCADO_PAGO_ACCESS_TOKEN=
# Webhook secret signature (Dashboard → Webhooks) — used to validate x-signature on POST /api/webhooks/mercado-pago.
MERCADO_PAGO_WEBHOOK_SECRET=
# Optional: full URL for payment notifications (e.g. https://your-domain.com/api/webhooks/mercado-pago). If unset, derived from NEXT_PUBLIC_SITE_URL or VERCEL_URL.
# MERCADO_PAGO_NOTIFICATION_URL=
# Optional: payer email sent to MP when creating Pix (MP requires an email). If unset, a unique placeholder is generated per payment.
# MERCADO_PAGO_DONATION_PAYER_EMAIL=
# Optional: public site origin for building default notification_url (e.g. https://soundquest.example).
NEXT_PUBLIC_SITE_URL=
# Stripe payment or donation link (support page).
NEXT_PUBLIC_STRIPE_URL=
# GitHub profile or repo URL (support page).
NEXT_PUBLIC_GITHUB_URL=
